{
    "name": "pixelcms/app",
    "description": "Pixel CMS - Sistema de gestión de contenidos gubernamentales",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7",
        "phpoffice/phpspreadsheet": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
